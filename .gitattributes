# Auto-detect text files and normalize line endings
* text=auto

# Explicitly declare text files
*.kt text
*.kts text
*.java text
*.xml text
*.json text
*.properties text
*.md text
*.pro text

# Shell scripts should use LF
*.sh text eol=lf
gradlew text eol=lf

# Batch scripts should use CRLF
*.bat text eol=crlf

# Binary files
*.jar binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.webp binary
